# Copy to .env (in the project folder or in ~/.phd_finder/.env) and fill in.
# ALL keys are optional — the app runs in limited mode without them.
# NEVER commit your real .env.

# --- LLM (optional, enables better document drafting) ---
# Any OpenAI-compatible API works (OpenAI, Azure, OpenRouter, local Ollama, ...)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# --- Semantic Scholar (optional; raises rate limits) ---
SEMANTIC_SCHOLAR_API_KEY=

# --- Gmail OAuth (create a "Desktop app" OAuth client in Google Cloud Console) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Outlook / Microsoft 365 OAuth (register a public client app in Entra ID
#     with delegated Mail.Send permission) ---
MS_CLIENT_ID=
MS_TENANT_ID=common

# --- Politeness: contact email sent in API User-Agent headers (recommended
#     by OpenAlex; gets you the faster "polite pool") ---
CONTACT_EMAIL=

# --- Safety ---
DAILY_SEND_LIMIT=10
